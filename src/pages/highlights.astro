---
import BaseLayout from '../layouts/BaseLayout.astro';
// The list itself is rendered client-side from localStorage by highlights.js
// (it's per-visitor data) — this page is just the shell, empty state, and the
// "clear all" control.
---
<BaseLayout title="Highlights" description="Every passage you've highlighted across The Go Reference, gathered in one place and linked back to where you found it — your own reading notebook, kept in this browser and synced across your devices.">
  <nav class="dp-breadcrumb dp-kicker"><a href="/">The Go Reference</a> › <span>Highlights</span></nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="hl.eyebrow">Your notebook</p>
    <h1 data-i18n="hl.h1">Highlights</h1>
    <p class="dp-hero__lede" data-i18n-html="hl.lede">
      Select any text while you read and hit <strong>Highlight</strong> — or tap <strong>✎</strong>
      to highlight and add a <strong>note</strong>. It's saved here and marked on the page.
      Everything stays in this browser (and syncs across your devices if you add an email), so this
      is your private, growing reference of the bits that mattered — and why.
    </p>
  </header>

  <div class="dp-highlights" data-dp-highlights>
    <div class="dp-highlights__bar">
      <p class="dp-kicker">
        <strong data-dp-highlights-count>0</strong>
        <span data-i18n="hl.saved">highlights saved</span>
      </p>
      <div class="dp-highlights__controls">
        <label class="dp-hl-optout" title="Counts are anonymous — only the number of readers per paragraph is shared, never your text, notes, or identity.">
          <input type="checkbox" data-dp-hl-stats-optout checked />
          <span data-i18n="hl.statsShare">Share anonymous highlight counts</span>
        </label>
        <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-highlights-clear hidden data-i18n="hl.clear">
          Clear all
        </button>
      </div>
    </div>

    <div class="dp-highlights__empty" data-dp-highlights-empty hidden>
      <p class="dp-review__emoji">🖍️</p>
      <h2 data-i18n="hl.noneTitle">Nothing highlighted yet</h2>
      <p class="dp-review__hint" data-i18n="hl.noneBody">
        Open any page, select a sentence that clicks, and choose a colour. It'll appear here,
        linked straight back to the spot you found it.
      </p>
      <a class="dp-btn dp-btn--primary" href="/" data-i18n="hl.browse">Browse the tracks →</a>
    </div>

    <div data-dp-highlights-list></div>
  </div>
</BaseLayout>
