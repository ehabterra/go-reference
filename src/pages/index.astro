---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const patterns = await getCollection('patterns');
const concurrency = await getCollection('concurrency');
const dsa = await getCollection('dsa');
const fundamentals = await getCollection('fundamentals');
const stdlib = await getCollection('stdlib');
const web = await getCollection('web');
const internals = await getCollection('internals');
const systems = await getCollection('systems');
const security = await getCollection('security');
const cloud = await getCollection('cloud');
const architecture = await getCollection('architecture');

const gofCount = patterns.filter((p) => p.data.gof).length;
const concPatternCount = patterns.filter((p) => p.data.category === 'concurrency').length;
const concTopicCount = concurrency.filter((p) => p.data.kind === 'topic').length;
const dsaCount = dsa.filter((p) => p.data.kind === 'topic').length;
const funCount = fundamentals.filter((p) => p.data.kind === 'topic').length;
const stdlibCount = stdlib.filter((p) => p.data.kind === 'topic').length;
const webCount = web.filter((p) => p.data.kind === 'topic').length;
const internalsCount = internals.filter((p) => p.data.kind === 'topic').length;
// these tracks open with a kind:"guide" intro page (a real page in the track),
// so count guide + topic — not just topic — to reflect the true page count.
const systemsCount = systems.filter((p) => p.data.kind !== 'pattern').length;
const securityCount = security.filter((p) => p.data.kind !== 'pattern').length;
const cloudCount = cloud.filter((p) => p.data.kind !== 'pattern').length;
const architectureCount = architecture.filter((p) => p.data.kind !== 'pattern').length;

// unified progress across every page in the reference
const allSlugs = [...patterns, ...concurrency, ...dsa, ...fundamentals, ...stdlib, ...web, ...internals, ...systems, ...security, ...cloud, ...architecture].map((p) => p.id).join(',');

// Ordered per-track manifest (same order the Pager uses) — embedded as JSON
// so the client-side resume card can name the last page and pick "next up".
const trackList = [
  { base: '/fundamentals', name: 'Go Fundamentals', entries: fundamentals },
  { base: '/patterns', name: 'Design Patterns', entries: patterns },
  { base: '/concurrency', name: 'Concurrency', entries: concurrency },
  { base: '/dsa', name: 'Data Structures & Algorithms', entries: dsa },
  { base: '/stdlib', name: 'Standard Library & Tooling', entries: stdlib },
  { base: '/web', name: 'Networking & Web', entries: web },
  { base: '/internals', name: 'Go Internals', entries: internals },
  { base: '/systems', name: 'Systems Programming', entries: systems },
  { base: '/security', name: 'Security', entries: security },
  { base: '/cloud', name: 'Cloud-Native', entries: cloud },
  { base: '/architecture', name: 'Architecture', entries: architecture },
];
const resumeManifest = trackList.map((t) => ({
  base: t.base,
  name: t.name,
  pages: [...t.entries]
    .sort((a, b) => a.data.order - b.data.order)
    .map((e) => ({ id: e.id, title: e.data.title, ...(e.data.quiz?.length ? { q: 1 } : {}) })),
}));
---
<BaseLayout>
  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="home.eyebrow">A visual, Go-first reference</p>
    <h1>The Go Reference</h1>
    <p class="dp-hero__lede" data-i18n-html="home.lede">
      Deeply learn the things that make Go engineers great — from the language itself to data structures,
      concurrency, the standard library, networking, internals, systems programming, security, cloud-native
      and architecture — with clear diagrams, idiomatic Go you can <strong>run right here</strong>, quizzes,
      and progress that sticks. Pick a track and start.
    </p>
  </header>

  <section class="dp-resume" data-dp-resume hidden>
    <div class="dp-resume__info">
      <p class="dp-resume__kicker" data-i18n="home.resumeKicker">Continue where you left off</p>
      <h2 class="dp-resume__title" data-dp-resume-title></h2>
      <p class="dp-resume__meta">
        <span data-dp-resume-track></span> · <span data-dp-resume-count></span>
        <span data-i18n="home.learnedSuffix">learned</span>
      </p>
    </div>
    <div class="dp-resume__actions">
      <a class="dp-btn dp-btn--primary" data-dp-resume-link><span data-i18n="home.resume">Resume</span> →</a>
      <a class="dp-btn dp-btn--ghost" data-dp-resume-next hidden>
        <span data-i18n="home.nextUp">Next up</span>: <span data-dp-resume-next-title></span>
      </a>
    </div>
  </section>
  <section class="dp-resume dp-resume--review" data-dp-review-card hidden>
    <div class="dp-resume__info">
      <p class="dp-resume__kicker" data-i18n="home.reviewKicker">Daily review</p>
      <h2 class="dp-resume__title">
        <span data-dp-review-count>0</span> <span data-i18n="home.reviewDue">pages due for a quick recall</span>
      </h2>
      <p class="dp-resume__meta" data-i18n="home.reviewNote">A few minutes of answering from memory is what makes it stick for good.</p>
    </div>
    <div class="dp-resume__actions">
      <a class="dp-btn dp-btn--primary" href="/review/"><span data-i18n="home.reviewStart">Start review</span> →</a>
    </div>
  </section>
  <script type="application/json" id="dp-resume-manifest" set:html={JSON.stringify(resumeManifest).replace(/</g, '\\u003c')}></script>

  <div class="dp-overall">
    <div class="dp-overall__top">
      <strong data-i18n="home.progressTitle">Your overall progress</strong>
      <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-reset data-i18n="home.reset">Reset</button>
    </div>
    <div class="dp-progress" data-dp-progress data-slugs={allSlugs}>
      <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
      <span class="dp-progress__label"></span>
    </div>
    <p class="dp-kicker" style="margin:.7rem 0 0;" data-i18n="home.progressNote">
      Tracked across every track — mark any page “learned” and this fills up. Saved in your browser.
    </p>
  </div>

  <h2 class="dp-section-head" style="border:0;margin-top:2.4rem;" data-i18n="home.pickTrack">Pick a track</h2>
  <div class="dp-topics">
    <a class="dp-topic" data-cat="basics" href="/fundamentals/">
      <div class="dp-topic__icon">🐹</div>
      <h3>Go Fundamentals</h3>
      <p data-i18n="home.fundamentals.desc">The language itself, Go-first — syntax and types, functions and pointers, structs, methods and interfaces, generics, and idiomatic error handling.</p>
      <span class="dp-topic__stat">{funCount} <span data-i18n="home.fundamentals.stat">topics · syntax → interfaces · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="behavioral" href="/patterns/">
      <div class="dp-topic__icon">🧩</div>
      <h3>Design Patterns</h3>
      <p data-i18n="home.patterns.desc">All {gofCount} Gang-of-Four patterns plus {concPatternCount} Go concurrency patterns — creational, structural, behavioral — each Go-first with diagrams, runnable code and trade-offs.</p>
      <span class="dp-topic__stat">{gofCount + concPatternCount} <span data-i18n="home.patterns.stat">patterns · diagrams · playground · quizzes</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="building-blocks" href="/concurrency/">
      <div class="dp-topic__icon">🔀</div>
      <h3>Concurrency</h3>
      <p data-i18n-html="home.concurrency.desc">A deep, practical guide to Go concurrency — races, goroutines, channels, <code>select</code>, the <code>sync</code> package, the memory model, context, and the runtime scheduler.</p>
      <span class="dp-topic__stat">{concTopicCount} <span data-i18n="home.concurrency.stat">topics · foundations → runtime · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="algorithms" href="/dsa/">
      <div class="dp-topic__icon">🧮</div>
      <h3>Data Structures &amp; Algorithms</h3>
      <p data-i18n="home.dsa.desc">Go-first data structures and algorithms — complexity analysis, diagrams and runnable implementations, from Big-O to graphs and dynamic programming.</p>
      <span class="dp-topic__stat">{dsaCount} <span data-i18n="home.dsa.stat">topics · Big-O → graphs · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="essentials" href="/stdlib/">
      <div class="dp-topic__icon">🧰</div>
      <h3>Standard Library &amp; Tooling</h3>
      <p data-i18n="home.stdlib.desc">The batteries Go includes — fmt and io, encoding/json, files and the CLI, structured logging, plus testing, benchmarks, the race detector and pprof profiling.</p>
      <span class="dp-topic__stat">{stdlibCount} <span data-i18n="home.stdlib.stat">topics · stdlib → tooling · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="net-basics" href="/web/">
      <div class="dp-topic__icon">🌐</div>
      <h3>Networking &amp; Web</h3>
      <p data-i18n="home.web.desc">Build services in Go — TCP and UDP sockets, net/http servers and clients, routing and middleware, REST and gRPC, WebSockets, TLS, and database/sql with transactions.</p>
      <span class="dp-topic__stat">{webCount} <span data-i18n="home.web.stat">topics · sockets → databases · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="memory" href="/internals/">
      <div class="dp-topic__icon">⚙️</div>
      <h3>Go Internals</h3>
      <p data-i18n="home.internals.desc">How Go runs under the hood — the stack and heap, escape analysis, the allocator and garbage collector, memory layout and unsafe, interfaces' itab, the goroutine scheduler, and the compiler toolchain.</p>
      <span class="dp-topic__stat">{internalsCount} <span data-i18n="home.internals.stat">topics · memory → toolchain · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="syscalls" href="/systems/">
      <div class="dp-topic__icon">🛠️</div>
      <h3>Systems Programming</h3>
      <p data-i18n="home.systems.desc">Talk to the OS in Go — system calls and file descriptors, files and directories, processes and signals, scheduling and file watching, pipes and Unix sockets for IPC, and memory-mapped files.</p>
      <span class="dp-topic__stat">{systemsCount} <span data-i18n="home.systems.stat">topics · syscalls → IPC · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="offensive" href="/security/">
      <div class="dp-topic__icon">🛡️</div>
      <h3>Security</h3>
      <p data-i18n="home.security.desc">Offensive and defensive security in Go — the hacker mindset and authorized testing, port scanning and recon, fuzzing and packet analysis, cryptography done right, and secure coding from injection defense to supply-chain safety.</p>
      <span class="dp-topic__stat">{securityCount} <span data-i18n="home.security.stat">topics · recon → defense · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="containers" href="/cloud/">
      <div class="dp-topic__icon">☁️</div>
      <h3>Cloud-Native</h3>
      <p data-i18n="home.cloud.desc">Run Go in production — containers and Kubernetes, health probes and graceful shutdown, structured logs, metrics and tracing, message queues and event-driven design, and resilience patterns like retries, circuit breakers and sagas.</p>
      <span class="dp-topic__stat">{cloudCount} <span data-i18n="home.cloud.stat">topics · containers → resilience · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>

    <a class="dp-topic" data-cat="arch-principles" href="/architecture/">
      <div class="dp-topic__icon">🏛️</div>
      <h3>Architecture</h3>
      <p data-i18n="home.architecture.desc">Design systems that last — Domain-Driven Design and bounded contexts, aggregates and repositories, hexagonal/clean architecture, an idiomatic Go project layout, and the modular-monolith-vs-microservices decision.</p>
      <span class="dp-topic__stat">{architectureCount} <span data-i18n="home.architecture.stat">topics · DDD → boundaries · runnable</span></span>
      <span class="dp-topic__go" data-i18n="home.enter">Enter →</span>
    </a>
  </div>

  <section data-dp-toplikes hidden>
    <h2 class="dp-section-head" style="border:0;margin-top:2.6rem;" data-i18n="home.topLikes">Most liked pages</h2>
    <div class="dp-toplikes" data-dp-toplikes-grid></div>
  </section>

  <h2 class="dp-section-head" style="border:0;margin-top:2.8rem;" data-i18n="home.how">How it works</h2>
  <div class="dp-features">
    <div class="dp-feature">
      <div class="dp-feature__icon">📊</div>
      <h3 data-i18n="home.f1.t">See it, then read it</h3>
      <p data-i18n="home.f1.d">Mermaid diagrams make the relationships obvious before you read a line of code.</p>
    </div>
    <div class="dp-feature">
      <div class="dp-feature__icon">▶️</div>
      <h3 data-i18n="home.f2.t">Run it in place</h3>
      <p data-i18n="home.f2.d">Every example is an editable Go playground that compiles and runs against the real Go toolchain.</p>
    </div>
    <div class="dp-feature">
      <div class="dp-feature__icon">🐹</div>
      <h3 data-i18n="home.f3.t">Go-first, not translated</h3>
      <p data-i18n="home.f3.d">Idiomatic Go throughout — interfaces, goroutines and channels, not Java in disguise.</p>
    </div>
    <div class="dp-feature">
      <div class="dp-feature__icon">🧠</div>
      <h3 data-i18n="home.f4.t">Made to remember</h3>
      <p data-i18n="home.f4.d">A quiz on every page and progress tracking turn passive reading into a journey you finish.</p>
    </div>
  </div>
</BaseLayout>
