---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategorySection from '../../components/CategorySection.astro';
import Card from '../../components/Card.astro';
import { readingTime } from '../../lib/reading-time';
import SkillTree from '../../components/SkillTree.astro';
import { CONCURRENCY_CATEGORIES } from '../../lib/consts';

const topics = await getCollection('concurrency');
const slugs = topics.filter((t) => t.data.kind === 'topic').map((t) => t.id).join(',');
const cheat = topics.find((t) => t.id === 'quick-reference');
---
<BaseLayout title="Concurrency" description="A deep, Go-first guide to concurrency — races, goroutines, channels, select, sync, the memory model, context and the scheduler.">
  <nav class="dp-breadcrumb dp-kicker"><a href="/">The Go Reference</a> › <span>Concurrency</span></nav>

  <header class="dp-hero">
    <p class="dp-hero__eyebrow" data-i18n="con.eyebrow">A deep, Go-first guide</p>
    <h1 data-i18n="con.h1">Go Concurrency, demystified</h1>
    <p class="dp-hero__lede" data-i18n-html="con.lede">
      From the failure modes you must design against to the runtime that schedules it all — goroutines,
      channels, <code>select</code>, the <code>sync</code> package, the memory model, context, and the M:N
      scheduler. Grounded in <em>Concurrency in Go</em>, with diagrams and runnable code on every page.
    </p>
    <div class="dp-hero__cta">
      <a class="dp-btn dp-btn--primary" href="/concurrency/concurrency-vs-parallelism/" data-i18n="ui.startJourney">Start the journey →</a>
      <a class="dp-btn dp-btn--ghost" href="#building-blocks" data-i18n="con.cta.jump">Jump to the building blocks</a>
    </div>
  </header>

  <div class="dp-overall">
    <div class="dp-overall__top">
      <strong data-i18n="con.progressTitle">Your concurrency progress</strong>
      <button class="dp-btn dp-btn--ghost dp-btn--sm" data-dp-reset data-i18n="ui.reset">Reset</button>
    </div>
    <div class="dp-progress" data-dp-progress data-slugs={slugs}>
      <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
      <span class="dp-progress__label"></span>
    </div>
    <p class="dp-kicker" style="margin:.7rem 0 0;" data-i18n="con.progressNote">Mark a topic “learned” on its page and watch the bars fill.</p>
  </div>

  <SkillTree entries={topics} categories={CONCURRENCY_CATEGORIES} base="/concurrency" />

  {CONCURRENCY_CATEGORIES.map((c) => (
    <CategorySection cat={c.key} title={c.title} blurb={c.blurb} collection="concurrency" base="/concurrency" />
  ))}

  <CategorySection
    cat="concurrency"
    title="Concurrency Patterns"
    blurb="The composable recipes built from these primitives — pipelines, worker pools, fan-out/in, errgroup and safe cancellation. (Part of the Design Patterns track.)"
    titleKey="con.patterns.title"
    blurbKey="con.patterns.blurb"
    collection="patterns"
    base="/patterns"
  />

  {cheat && (
    <Fragment>
      <h2 class="dp-section-head" style="border:0;" data-i18n="con.revise">Revise</h2>
      <div class="dp-grid">
        <Card
          slug={cheat.id}
          category="practice"
          title={cheat.data.title}
          intent={cheat.data.intent}
          numLabel={`REFERENCE · ${cheat.data.difficulty}`}
          footLabel="One-page recap"
          minutes={readingTime(cheat.body)}
          base="/concurrency"
        />
      </div>
    </Fragment>
  )}

  <div class="dp-callout dp-callout--go" style="margin-top:2.6rem;">
    <p class="dp-callout__title" data-i18n="con.go.title">🐹 The two Go proverbs to keep in mind</p>
    <p data-i18n="con.go.body">
      “Don't communicate by sharing memory; share memory by communicating.” And: “Concurrency is not
      parallelism.” Almost everything here is a consequence of taking those two seriously.
    </p>
  </div>
</BaseLayout>
