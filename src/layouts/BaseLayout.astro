---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESC } from '../lib/consts';
import ar from '../i18n/ar.json';

interface Props { title?: string; description?: string; }
const { title, description } = Astro.props;
const pageTitle = title ? `${title} · The Go Reference` : SITE_TITLE;
const desc = description ?? SITE_DESC;

// Build a lightweight search index for the ⌘K command palette.
const patterns = await getCollection('patterns');
const concurrency = await getCollection('concurrency');
const dsa = await getCollection('dsa');
const fundamentals = await getCollection('fundamentals');
const stdlib = await getCollection('stdlib');
const web = await getCollection('web');
const internals = await getCollection('internals');
const systems = await getCollection('systems');
const security = await getCollection('security');
const cloud = await getCollection('cloud');
const searchIndex = [
  ...patterns.map((p) => ({ t: p.data.title, u: `/patterns/${p.id}/`, c: p.data.category, s: 'Design Patterns', i: p.data.intent })),
  ...concurrency.map((p) => ({ t: p.data.title, u: `/concurrency/${p.id}/`, c: p.data.category, s: 'Concurrency', i: p.data.intent })),
  ...fundamentals.map((p) => ({ t: p.data.title, u: `/fundamentals/${p.id}/`, c: p.data.category, s: 'Fundamentals', i: p.data.intent })),
  ...dsa.map((p) => ({ t: p.data.title, u: `/dsa/${p.id}/`, c: p.data.category, s: 'DSA', i: p.data.intent })),
  ...stdlib.map((p) => ({ t: p.data.title, u: `/stdlib/${p.id}/`, c: p.data.category, s: 'Stdlib', i: p.data.intent })),
  ...web.map((p) => ({ t: p.data.title, u: `/web/${p.id}/`, c: p.data.category, s: 'Web', i: p.data.intent })),
  ...internals.map((p) => ({ t: p.data.title, u: `/internals/${p.id}/`, c: p.data.category, s: 'Go Internals', i: p.data.intent })),
  ...systems.map((p) => ({ t: p.data.title, u: `/systems/${p.id}/`, c: p.data.category, s: 'Systems', i: p.data.intent })),
  ...security.map((p) => ({ t: p.data.title, u: `/security/${p.id}/`, c: p.data.category, s: 'Security', i: p.data.intent })),
  ...cloud.map((p) => ({ t: p.data.title, u: `/cloud/${p.id}/`, c: p.data.category, s: 'Cloud-Native', i: p.data.intent })),
];
---
<!doctype html>
<html lang="en" data-lang="en" dir="ltr">
  <head>
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('dp-lang') === 'ar') {
            var d = document.documentElement;
            d.dataset.lang = 'ar';
            d.dir = 'rtl';
          }
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#080b12" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <div class="dp-readbar" id="dp-readbar"></div>
    <Nav />
    <main class="dp-container">
      <slot />
    </main>
    <Footer />

    <!-- ⌘K command palette -->
    <div class="dp-cmdk" id="dp-cmdk" aria-hidden="true">
      <div class="dp-cmdk__backdrop" data-dp-cmdk-close></div>
      <div class="dp-cmdk__panel" role="dialog" aria-modal="true" aria-label="Search the reference">
        <input class="dp-cmdk__input" id="dp-cmdk-input" type="text" placeholder="Search patterns &amp; concurrency…" autocomplete="off" spellcheck="false" />
        <ul class="dp-cmdk__results" id="dp-cmdk-results"></ul>
        <div class="dp-cmdk__hint">
          <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
          <span><kbd>↵</kbd> open</span>
          <span><kbd>esc</kbd> close</span>
        </div>
      </div>
    </div>
    <script type="application/json" id="dp-search-index" set:html={JSON.stringify(searchIndex)}></script>
    <script type="application/json" id="dp-i18n" set:html={JSON.stringify(ar)}></script>

    <script>
      import '../scripts/progress.js';
      import '../scripts/ui.js';
    </script>
  </body>
</html>
