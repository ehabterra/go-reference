---
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import DraftScaffold from '../components/DraftScaffold.astro';
import Tradeoffs from '../components/Tradeoffs.astro';
import Related from '../components/Related.astro';
import QuizBlock from '../components/QuizBlock.astro';
import Pager from '../components/Pager.astro';
import Comments from '../components/Comments.astro';
import LikeButton from '../components/islands/LikeButton.tsx';

const {
  entry,
  collection = 'patterns',
  base = '/patterns',
  sectionTitle = 'Design Patterns',
  sectionHref = '/patterns/',
  relatedHeading = 'Related patterns',
  topicLabel = 'Concurrency',
} = Astro.props;
const d = entry.data;
const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const catLabel = cap(d.category.replace(/-/g, ' '));

// Per-page Arabic content (ordered to match the runtime block collector).
const contentModules = import.meta.glob('../i18n/content/*.json', { eager: true });
const contentAr = (contentModules[`../i18n/content/${entry.id}.json`] as any)?.default ?? [];
---
<BaseLayout title={d.title} description={d.intent}>
  <article>
    <nav class="dp-breadcrumb dp-kicker">
      <a href={sectionHref}>{sectionTitle}</a> › <span>{catLabel}</span> › <span>{d.title}</span>
    </nav>

    <PageHeader data={d} slug={entry.id} topicLabel={topicLabel} />

    <div class="dp-article">
      <div class="dp-article__body dp-prose">
        <slot />
        {d.status !== 'ready' && <DraftScaffold data={d} />}
        <Tradeoffs data={d} />
        <Related related={d.related} collection={collection} base={base} heading={relatedHeading} />
        {d.quiz.length > 0 && <QuizBlock quiz={d.quiz} />}
        <div class="dp-like-row">
          <span class="dp-like-row__label">Enjoyed this page?</span>
          <LikeButton client:visible page={`${base}/${entry.id}`} />
        </div>
        <Pager slug={entry.id} collection={collection} base={base} />
        <Comments />
      </div>

      <aside class="dp-article__toc" aria-label="On this page">
        <div class="dp-article__toc-inner">
          <p class="dp-toc-title">On this page</p>
          <ul class="dp-toc" data-dp-toc></ul>
          <p class="dp-toc-title" style="margin-top:1.5rem">Your progress</p>
          <button class="dp-btn" data-dp-learn={entry.id} aria-pressed="false">
            <span data-dp-learn-label>Mark as learned</span>
          </button>
        </div>
      </aside>
    </div>
  </article>

  <script type="application/json" id="dp-content-ar" set:html={JSON.stringify(contentAr)}></script>
  <script>import '../scripts/mermaid.js';</script>
</BaseLayout>
