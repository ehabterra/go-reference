---
import { getCollection } from 'astro:content';
import Card from './Card.astro';

interface Props {
  cat: string;
  title: string;
  blurb: string;
  collection?: 'patterns' | 'concurrency';
  base?: string;
}
const { cat, title, blurb, collection = 'patterns', base = '/patterns' } = Astro.props;

const all = await getCollection(collection);
const items = all
  .filter((p) => p.data.category === cat)
  .sort((a, b) => a.data.order - b.data.order);
const slugs = items.map((p) => p.id).join(',');
---
<section class="dp-cat" id={cat}>
  <div class="dp-section-head">
    <h2><span class="dp-badge" data-cat={cat}><span class="dp-dot"></span>{title}</span></h2>
    <p>{blurb}</p>
    {items.length > 0 && (
      <div class="dp-progress" data-dp-progress data-slugs={slugs} style="margin-top:.9rem;max-width:440px;">
        <div class="dp-progress__track"><div class="dp-progress__fill"></div></div>
        <span class="dp-progress__label"></span>
      </div>
    )}
  </div>
  {items.length === 0 ? (
    <p class="dp-kicker" style="margin-top:-.4rem;">🚧 Coming soon.</p>
  ) : (
    <div class="dp-grid">
      {items.map((p) => (
        <Card
          slug={p.id}
          category={p.data.category}
          title={p.data.title}
          intent={p.data.intent}
          order={p.data.order}
          difficulty={p.data.difficulty}
          status={p.data.status}
          base={base}
        />
      ))}
    </div>
  )}
</section>
