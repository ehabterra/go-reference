---
/*
  Bilingual section heading. Renders one <h2>/<h3> (so the table of contents
  stays single-entry) with English + Arabic spans; CSS shows the active one,
  and the TOC reads only the visible language.

  Usage in MDX:
    <H en="The problem" ar="المشكلة" />
    <H lvl={3} en="Idiomatic Go" ar="Go الاصطلاحية" />
*/
interface Props { lvl?: 2 | 3; en: string; ar?: string; }
const { lvl = 2, en, ar } = Astro.props;
const id = en.toLowerCase().replace(/[^\w]+/g, '-').replace(/^-+|-+$/g, '');
const Tag = `h${lvl}` as 'h2' | 'h3';
---
<Tag id={id}>
  <span class="tr-en">{en}</span>
  {ar && <span class="tr-ar" lang="ar" dir="rtl">{ar}</span>}
</Tag>
