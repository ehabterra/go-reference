---
import { getCollection } from 'astro:content';
const { related, collection = 'patterns', base = '/patterns', heading = 'Related patterns' } = Astro.props as {
  related: string[];
  collection?: 'patterns' | 'concurrency' | 'dsa' | 'fundamentals' | 'stdlib' | 'web' | 'internals' | 'systems' | 'security' | 'cloud' | 'architecture';
  base?: string;
  heading?: string;
};
const all = await getCollection(collection);
const items = (related ?? [])
  .map((slug) => all.find((p) => p.id === slug))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---
{items.length > 0 && (
  <Fragment>
    <h2 id="related">{heading}</h2>
    <div class="dp-grid">
      {items.map((p) => (
        <a class="dp-card" data-cat={p.data.category} data-slug={p.id} href={`${base}/${p.id}/`}>
          <span class="dp-card__num">{p.data.category}</span>
          <span class="dp-card__title">{p.data.title}</span>
          <p class="dp-card__intent">{p.data.intent}</p>
        </a>
      ))}
    </div>
  </Fragment>
)}
