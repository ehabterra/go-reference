---
interface Props {
  slug: string;
  category: string;
  title: string;
  intent: string;
  intent_ar?: string;
  order?: number;
  difficulty?: string;
  status?: string;
  numLabel?: string;
  footLabel?: string;
  base?: string;
}
const { slug, category, title, intent, intent_ar, order, difficulty, status, numLabel, footLabel, base = '/patterns' } = Astro.props;
---
<a class="dp-card" data-cat={category} data-slug={slug} href={`${base}/${slug}/`}>
  <span class="dp-card__num">{numLabel ?? `${order} · ${difficulty}`}</span>
  <span class="dp-card__title">{title}</span>
  <p class="dp-card__intent">
    <span class="tri-en">{intent}</span>
    {intent_ar && <span class="tri-ar" lang="ar" dir="rtl">{intent_ar}</span>}
  </p>
  <span class="dp-card__foot">
    <span>{footLabel ?? (status === 'ready' ? '✦ Complete' : 'Draft')}</span>
    <span class="dp-card__check" aria-hidden="true">✓</span>
  </span>
</a>
