---
interface Props {
  slug: string;
  category: string;
  title: string;
  intent: string;
  order?: number;
  difficulty?: string;
  status?: string;
  numLabel?: string;
  footLabel?: string;
  base?: string;
  minutes?: number;
}
const { slug, category, title, intent, order, difficulty, status, numLabel, footLabel, base = '/patterns', minutes } = Astro.props;
---
<a class="dp-card" data-cat={category} data-slug={slug} href={`${base}/${slug}/`}>
  <span class="dp-card__num">{numLabel ?? `${order} · ${difficulty}`}</span>
  <span class="dp-card__title">{title}</span>
  <p class="dp-card__intent" data-i18n-html={`intent.${slug}`}>{intent}</p>
  <span class="dp-card__foot">
    <span>
      {footLabel ?? (status === 'ready' ? '✦ Complete' : 'Draft')}
      {minutes && <span class="dp-card__time">· ⏱ {minutes} min</span>}
    </span>
    <span class="dp-card__check" aria-hidden="true">✓</span>
  </span>
</a>
