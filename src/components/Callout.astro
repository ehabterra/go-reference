---
interface Props {
  type?: 'intent' | 'analogy' | 'problem' | 'go' | 'gotcha' | 'tip';
  title?: string;
}
const { type = 'intent', title } = Astro.props;
---
<div class={`dp-callout dp-callout--${type}`}>
  {title && (
    <p class="dp-callout__title"><span>{title}</span></p>
  )}
  <slot />
</div>
